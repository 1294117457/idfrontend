{
  "name": "idfrontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite --open --mode dev",
    "build": "vue-tsc --build && vite build --mode prod",
    "build:test": "vite build --mode test",
    "preview": "vite preview",
    "type-check": "vue-tsc --build",
    "lint": "oxlint . --fix -D correctness --ignore-path .gitignore",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@popperjs/core": "^2.11.8",
    "axios": "^1.12.2",
    "dompurify": "^3.3.3",
    "element-plus": "^2.11.3",
    "marked": "^18.0.0",
    "pinia": "^3.0.3",
    "vue": "^3.5.18",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@tsconfig/node22": "^22.0.2",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.16.5",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.7.0",
    "oxlint": "~1.8.0",
    "prettier": "3.6.2",
    "tailwindcss": "^4.1.0",
    "typescript": "~5.8.0",
    "vite": "^7.0.6",
    "vite-plugin-vue-devtools": "^8.0.0",
    "vue-tsc": "^3.0.4"
  }
}
